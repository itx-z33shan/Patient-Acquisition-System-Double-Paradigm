# ============================================================
#  SMILE DENTAL CARE — Environment Template
#  Copy this to .env and fill in your real values.
#  This file IS safe to commit.
# ============================================================

# ── AI Chatbot (OpenRouter) ──────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ── WhatsApp (Lead Forms & Floating Button) ──────────────────
# Format: country code + number, no + or spaces  (e.g. 923119660535)
WHATSAPP_NUMBER=your_whatsapp_number_here

# ── Calendly Booking Widget ──────────────────────────────────
CALENDLY_URL=https://calendly.com/YOUR_USERNAME/YOUR_EVENT
